  "query": "\n            SELECT s.session_id, s.created_at, s.updated_at, us.user_id AS \"user_id?\"\n            FROM sessions s\n            LEFT JOIN user_sessions us ON us.session_id = s.session_id\n            WHERE s.session_id = $1\n            ",
